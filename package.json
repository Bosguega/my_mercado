{
  "name": "my_mercado",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:https": "node scripts/dev.mjs --https",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "analyze": "npx vite-bundle-analyzer dist/stats.html",
    "lighthouse": "npx lighthouse http://localhost:5173 --output=json --output-path=./lighthouse-report.json",
    "test:perf": "npm run build && npm run lighthouse",
    "test:perf:auto": "node scripts/testPerformance.js",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky || true",
    "husky:install": "husky",
    "husky:pre-commit": "chmod +x .husky/pre-commit",
    "husky:commit-msg": "chmod +x .husky/commit-msg"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.3",
    "@tanstack/react-query": "^5.95.2",
    "currency.js": "^2.0.4",
    "date-fns": "^4.1.0",
    "html5-qrcode": "^2.3.8",
    "lucide-react": "^0.577.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.6.0",
    "react-window": "^2.2.7",
    "recharts": "^3.8.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-basic-ssl": "^1.2.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "eslint": "^9.13.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^0.21.0",
    "vitest": "^3.2.4",
    "zod": "^4.3.6"
  }
}
