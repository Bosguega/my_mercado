{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "types": [],
    "rootDir": ".",
    "baseUrl": "."
  },
  "include": ["./**/*.ts", "./**/*.d.ts"]
}
